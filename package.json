{
  "name": "everything-audio-looper",
  "version": "0.1.0",
  "private": false,
  "description": "Record everyday sounds and turn them into a synced browser-based drum kit and techno loop.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/everything-audio-looper.git"
  },
  "homepage": "https://baditaflorin.github.io/everything-audio-looper/",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/prepare-pages-dir.mjs && tsc -b && vite build && node scripts/write-version.mjs && node scripts/copy-404.mjs && node scripts/check-pages-build.mjs",
    "preview": "vite preview",
    "pages-preview": "npm run build && node scripts/serve-static.mjs docs",
    "lint": "eslint . && prettier --check .",
    "fmt": "prettier --write .",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke": "bash scripts/smoke.sh",
    "audit": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "comlink": "^4.4.2",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
